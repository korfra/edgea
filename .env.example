MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_REGION=auto
MINIO_BUCKET_NAME=*
MINIO_ENDPOINT=10.10.20.1
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_PATH_STYLE=true
MINIO_CACHE_CONTROL=public, max-age=31536000, immutable

# Server Settings
MINIO_CDN_HOST=127.0.0.1
MINIO_CDN_PORT=3000

# Cache Settings (In-Memory)
CACHE_MAX_ITEMS=500
CACHE_MAX_SIZE_MB=50
CACHE_TTL_SEC=3600
