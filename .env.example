S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_REGION=auto
S3_BUCKET_NAME=*
S3_ENDPOINT=10.10.20.1
S3_PORT=9000
S3_USE_SSL=false
S3_PATH_STYLE=true
CDN_CACHE_CONTROL=public, max-age=31536000, immutable

# Server Settings
CDN_HOST=127.0.0.1
CDN_PORT=3000

# Cache Settings (In-Memory)
CACHE_MAX_ITEMS=500
CACHE_MAX_SIZE_MB=50
CACHE_TTL_SEC=3600
