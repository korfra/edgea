    "url": "git+https://github.com/korfra/edgea.git"
  },
  "author": {
    "name": "Suluh Sulistiawan",
    "email": "suluhs@aol.com",
    "url": "https://suluh.my.id"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/korfra/edgea/issues"
  },
  "homepage": "https://github.com/korfra/edgea",
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/minio": "^7.1.1",
    "prettier": "^3.8.3"
  },
  "peerDependencies": {
    "typescript": "^5.4.5"
  },
  "dependencies": {
    "hono": "^4.12.23",
    "lru-cache": "^11.5.1",
    "minio": "^8.0.7"
