{
  "name": "edgea",
  "version": "1.0.1",
  "description": "Serve S3 compatible files like Cloudflare R2",
  "module": "src/app.ts",
  "type": "module",
  "scripts": {
    "format": "prettier . --write",
    "test": "bun test"
  },
  "prettier": {
    "trailingComma": "es5",
    "semi": false,
